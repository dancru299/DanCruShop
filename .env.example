# Copy this file to .env.local for local development.
# Never commit .env.local or real secret values.

# Site
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=

# Supabase Auth, Database, and Storage.
# Keep SUPABASE_SERVICE_ROLE_KEY server-only. Never expose it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal payments (international card/PayPal checkout, non-VND).
# PAYPAL_ENV is "sandbox" (default) or "live". Webhook id comes from the PayPal
# developer dashboard after you register the /api/webhooks/paypal endpoint.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Lemon Squeezy (optional, external trust link only — no longer an integrated
# checkout). Set the public hosted store/product URL to show an "Also on Lemon
# Squeezy" link on product pages. The API keys below are only needed if you keep
# the legacy single-product Lemon Squeezy checkout action wired up somewhere.
NEXT_PUBLIC_LEMONSQUEEZY_STORE_URL=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Video provider: bunny or cloudflare.
VIDEO_PROVIDER=
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# Email delivery with Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# GitHub changelog on product detail pages (optional).
# Fine-grained PAT with read-only Contents + Metadata on the product repos.
# Server-only — never expose with a NEXT_PUBLIC_ prefix. Required only to read
# commits from private repos; public repos work without it (lower rate limit).
GITHUB_PAT=
